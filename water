    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const mobileMenuButton = document.getElementById('mobile-menu-button');
            const mobileMenu = document.getElementById('mobile-menu');
            mobileMenuButton.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });

            const accordionHeaders = document.querySelectorAll('.accordion-header');
            accordionHeaders.forEach(header => {
                header.addEventListener('click', () => {
                    const content = header.nextElementSibling;
                    const item = header.parentElement;
                    
                    if (content.style.maxHeight) {
                        content.style.maxHeight = null;
                        item.classList.remove('bg-gray-50');
                        header.querySelector('span:last-child').textContent = '+';
                    } else {
                        document.querySelectorAll('.accordion-content').forEach(c => c.style.maxHeight = null);
                        document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('bg-gray-50'));
                        document.querySelectorAll('.accordion-header span:last-child').forEach(s => s.textContent = '+');

                        content.style.maxHeight = content.scrollHeight + "px";
                        item.classList.add('bg-gray-50');
                        header.querySelector('span:last-child').textContent = '-';
                    }
                });
            });

            const sedaparData = {
                labels: ['Sin Ejecución / 0% Avance', 'Paralizado', 'En Ejecución', 'Finalizado'],
                datasets: [{
                    label: 'Nº de Proyectos',
                    data: [68, 15, 45, 42],
                    backgroundColor: [
                        'rgba(239, 68, 68, 0.7)',
                        'rgba(245, 158, 11, 0.7)',
                        'rgba(59, 130, 246, 0.7)',
                        'rgba(34, 197, 94, 0.7)'
                    ],
                    borderColor: [
                        'rgba(239, 68, 68, 1)',
                        'rgba(245, 158, 11, 1)',
                        'rgba(59, 130, 246, 1)',
                        'rgba(34, 197, 94, 1)'
                    ],
                    borderWidth: 1
                }]
            };

            const sedaparConfig = {
                type: 'bar',
                data: sedaparData,
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        title: {
                            display: true,
                            text: 'Estado de 170 Proyectos de SEDAPAR'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.x !== null) {
                                        label += context.parsed.x + ' proyectos';
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                             title: {
                                display: true,
                                text: 'Cantidad de Proyectos'
                            }
                        }
                    }
                }
            };

            const sedaparCtx = document.getElementById('sedaparProjectsChart').getContext('2d');
            new Chart(sedaparCtx, sedaparConfig);

            const coverageData = {
                labels: ['Con Cobertura', 'Sin Cobertura'],
                datasets: [{
                    label: 'Pre-Proyecto (75.3%)',
                    data: [75.3, 24.7],
                    backgroundColor: ['rgba(245, 158, 11, 0.7)', 'rgba(209, 213, 219, 0.7)'],
                    borderColor: ['rgba(245, 158, 11, 1)', 'rgba(209, 213, 219, 1)'],
                    borderWidth: 1
                }, {
                    label: 'Post-Proyecto (>95%)',
                    data: [95, 5],
                    backgroundColor: ['rgba(34, 197, 94, 0.7)', 'rgba(209, 213, 219, 0.7)'],
                    borderColor: ['rgba(34, 197, 94, 1)', 'rgba(209, 213, 219, 1)'],
                    borderWidth: 1,
                    hidden: true
                }]
            };

            const coverageConfig = {
                type: 'doughnut',
                data: coverageData,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            onClick: (e, legendItem, legend) => {
                                const index = legendItem.datasetIndex;
                                const ci = legend.chart;
                                const meta = ci.getDatasetMeta(index);
                                meta.hidden = !meta.hidden;
                                const otherMeta = ci.getDatasetMeta(index === 0 ? 1 : 0);
                                otherMeta.hidden = !otherMeta.hidden;
                                ci.update();
                            }
                        },
                        title: {
                            display: true,
                            text: 'Cobertura de Red Pública (Clic en leyenda para comparar)'
                        },
                        tooltip: {
                             callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed !== null) {
                                        label += context.parsed + '%';
                                    }
                                    return label;
                                }
                            }
                        }
                    }
                }
            };
            
            const coverageCtx = document.getElementById('coverageChart').getContext('2d');
            new Chart(coverageCtx, coverageConfig);
        });
    </script>
